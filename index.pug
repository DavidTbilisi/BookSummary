mixin book(item)
  .book
    .book__cover
      img(src=item.img, alt='წიგნის ყდა')
    h2.book__title= item.title
    h3.book__author= item.author
    p.book__desc= item.desc
    .buttons
      a.go-to-summary(href=item.summary_url, target="_blank") შეჯამების წაკითხვა

